@prefix : <urn:samm:org.eclipse.esmf.test:1.0.0#> .
@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.2.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.2.0#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.2.0#> .

:AspectWithSharedEntity a samm:Aspect ;
   samm:properties ( :p1 :p2 ) ;
   samm:operations ( ) .

:p1 a samm:Property ;
   samm:preferredName "Property 1"@en ;
   samm:characteristic :TheCharacteristic .

:p2 a samm:Property ;
   samm:preferredName "Property 2"@en ;
   samm:characteristic :TheCharacteristic .

:TheCharacteristic a samm-c:SingleEntity ;
   samm:dataType :SomeEntity .

:SomeEntity a samm:Entity ;
   samm:properties ( [ samm:property :entityProperty ; samm:optional true ] ) .

:entityProperty a samm:Property ;
   samm:preferredName "Entity Property"@en ;
   samm:exampleValue "entity property example" ;
   samm:characteristic samm-c:Text .
