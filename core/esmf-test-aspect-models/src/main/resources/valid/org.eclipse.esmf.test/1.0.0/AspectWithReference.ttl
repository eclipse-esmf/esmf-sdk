@prefix : <urn:samm:org.eclipse.esmf.test:1.0.0#> .
@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.2.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.2.0#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:AspectWithReference a samm:Aspect ;
   samm:preferredName "Aspect With Reference"@en ;
   samm:description "Test aspect with a SAMM reference property."@en ;
   samm:properties ( :myRef ) ;
   samm:operations ( ) .

:myRef a samm:Property ;
   samm:preferredName "My Reference"@en ;
   samm:description "A reference to another element."@en ;
   samm:characteristic samm-c:Reference ;
   samm:exampleValue "urn:example:target-element"^^xsd:anyURI .
