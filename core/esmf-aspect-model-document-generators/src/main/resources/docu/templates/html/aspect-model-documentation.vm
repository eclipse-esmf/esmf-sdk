<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="content-type" content="text/html; chartset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <style>
        .reset-all-styles {
            all: revert;
        }
    </style>
    <style>tailwind_css_placeholder</style>
    <style>/* MIT License | https://github.com/tailwindlabs/tailwindcss/blob/master/LICENSE */
    tocbot_css_placeholder</style>
    <style>custom_css_placeholder</style>
    <script>/* MIT License | https://github.com/anvaka/panzoom/blob/master/LICENSE */
    panzoom_js_placeholder;</script>
    <script>/* MIT License | https://github.com/tscanlin/tocbot/blob/master/LICENSE */
    tocbot_js_placeholder;</script>
    <script>
        window.onload = function () {
            const diagram = document.getElementById('aspect-model-diagram');
            const shell = diagram ? diagram.closest('.w-full.h-full.shadow-lg.overflow-hidden.p-4') : null;
            const container = shell || diagram?.parentElement;

            if (!diagram || !container) return;

            /* ── transform state ── */
            let scale = 1;
            let tx = 0;
            let ty = 0;

            /* ── animation ── */
            let animId = null;
            let animStart = null;
            let fromScale, fromTx, fromTy;
            let toScale,   toTx,   toTy;
            const DURATION = 220; // ms

            function easeInOut(t) {
                return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            }

            function applyTransform(s, x, y) {
                diagram.style.transform = `translate(${x}px, ${y}px) scale(${s})`;
                diagram.style.transformOrigin = '0 0';
            }

            function animateTo(ts) {
                if (!animStart) animStart = ts;
                const elapsed = ts - animStart;
                const progress = Math.min(elapsed / DURATION, 1);
                const ease = easeInOut(progress);

                const cs = fromScale + (toScale - fromScale) * ease;
                const cx = fromTx   + (toTx   - fromTx)   * ease;
                const cy = fromTy   + (toTy   - fromTy)   * ease;

                applyTransform(cs, cx, cy);

                if (progress < 1) {
                    animId = requestAnimationFrame(animateTo);
                } else {
                    scale = toScale;
                    tx    = toTx;
                    ty    = toTy;
                    animId = null;
                    animStart = null;
                }
            }

            function startAnimation(newScale, newTx, newTy) {
                // If animation is already running — start from the current visual position
                if (animId !== null) {
                    cancelAnimationFrame(animId);
                    animId = null;
                    // Read current visual state from the transform
                    const m = new DOMMatrix(diagram.style.transform);
                    fromScale = scale = m.a; // scale (a == d for uniform scaling)
                    fromTx    = tx    = m.e;
                    fromTy    = ty    = m.f;
                } else {
                    fromScale = scale;
                    fromTx    = tx;
                    fromTy    = ty;
                }

                toScale = newScale;
                toTx    = newTx;
                toTy    = newTy;

                animStart = null;
                animId = requestAnimationFrame(animateTo);
            }

            /* ── zoom calculation ── */
            const MIN_SCALE = 1;
            const MAX_SCALE = 8;
            const ZOOM_FACTOR = 1.3;

            function computeZoom(factor) {
                const rect = container.getBoundingClientRect();
                // Container center in its own local coordinates
                const cx = rect.width  / 2;
                const cy = rect.height / 2;

                // Current visual state (accounting for any in-progress animation)
                let curScale = scale, curTx = tx, curTy = ty;
                if (animId !== null) {
                    const m = new DOMMatrix(diagram.style.transform);
                    curScale = m.a;
                    curTx    = m.e;
                    curTy    = m.f;
                }

                const newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, curScale * factor));
                if (newScale === curScale) return null;

                // Point in diagram coordinates we want to keep fixed under the center
                const pivotX = (cx - curTx) / curScale;
                const pivotY = (cy - curTy) / curScale;

                // New offsets so the pivot stays under the center
                const newTx = cx - pivotX * newScale;
                const newTy = cy - pivotY * newScale;

                return { newScale, newTx, newTy };
            }

            function zoomIn() {
                const r = computeZoom(ZOOM_FACTOR);
                if (r) startAnimation(r.newScale, r.newTx, r.newTy);
            }

            function zoomOut() {
                const r = computeZoom(1 / ZOOM_FACTOR);
                if (r) startAnimation(r.newScale, r.newTx, r.newTy);
            }

            function reset() {
                startAnimation(1, 0, 0);
            }

            /* ── mouse wheel ── */
            container.addEventListener('wheel', (e) => {
                e.preventDefault();
                const factor = e.deltaY < 0 ? 1.1 : 1 / 1.1;
                const rect = container.getBoundingClientRect();

                let curScale = scale, curTx = tx, curTy = ty;
                if (animId !== null) {
                    const m = new DOMMatrix(diagram.style.transform);
                    curScale = m.a; curTx = m.e; curTy = m.f;
                    cancelAnimationFrame(animId);
                    animId = null; animStart = null;
                }

                const newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, curScale * factor));
                if (newScale === curScale) return;

                const mouseX = e.clientX - rect.left;
                const mouseY = e.clientY - rect.top;
                const pivotX = (mouseX - curTx) / curScale;
                const pivotY = (mouseY - curTy) / curScale;
                const newTx  = mouseX - pivotX * newScale;
                const newTy  = mouseY - pivotY * newScale;

                scale = newScale; tx = newTx; ty = newTy;
                applyTransform(scale, tx, ty);
            }, { passive: false });

            /* ── drag to pan ── */
            let dragging = false;
            let dragStartX, dragStartY, dragStartTx, dragStartTy;

            diagram.addEventListener('mousedown', (e) => {
                if (e.button !== 0) return;
                dragging = true;
                dragStartX  = e.clientX;
                dragStartY  = e.clientY;
                dragStartTx = tx;
                dragStartTy = ty;
                diagram.style.cursor = 'grabbing';
                e.preventDefault();
            });

            document.addEventListener('mousemove', (e) => {
                if (!dragging) return;
                tx = dragStartTx + (e.clientX - dragStartX);
                ty = dragStartTy + (e.clientY - dragStartY);
                applyTransform(scale, tx, ty);
            });

            document.addEventListener('mouseup', () => {
                dragging = false;
                diagram.style.cursor = 'grab';
            });

            diagram.style.cursor = 'grab';

            /* ── buttons ── */
            function toggleFs() {
                if (!shell) return;
                shell.classList.toggle('am-diag-fullscreen');
            }

            if (shell) {
                shell.querySelectorAll('[data-am-diag]').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const a = btn.getAttribute('data-am-diag');
                        if (a === 'zin')   zoomIn();
                        if (a === 'zout')  zoomOut();
                        if (a === 'reset') reset();
                        if (a === 'fs')    toggleFs();
                    });
                });
            }

            /* ── keyboard shortcuts ── */
            let armed = false;
            if (shell) {
                shell.addEventListener('mouseenter', () => (armed = true));
                shell.addEventListener('mouseleave', () => (armed = false));
            }

            document.addEventListener('keydown', (e) => {
                const inFs = shell?.classList.contains('am-diag-fullscreen');
                if (!inFs && !armed) return;

                const k = e.key;
                if (k === '+' || k === '=') { e.preventDefault(); zoomIn(); }
                else if (k === '-' || k === '_') { e.preventDefault(); zoomOut(); }
                else if (k === '0' || k === 'r' || k === 'R') { e.preventDefault(); reset(); }
                else if (k === 'f' || k === 'F') { e.preventDefault(); toggleFs(); }
                else if (k === 'Escape' && inFs) { e.preventDefault(); shell.classList.remove('am-diag-fullscreen'); }
            });

            /* ── init ── */
            applyTransform(1, 0, 0);
            // Dispose panzoom if it was previously attached
            if (window.__amPanzoom) {
                try { window.__amPanzoom.dispose(); } catch (_) {}
                window.__amPanzoom = null;
            }
        };
    </script>
    <title>$i18n.getText("docu.label.documentation") $aspectModel.getPreferredName($i18n.getLocale())</title>
</head>
<body>
<div class="dt-shell">
    <header class="dt-topbar">
        <div class="dt-topbar__inner">
            <div class="dt-brand">
                <h1 class="dt-title" id="$aspectModel.getName()">Aspect Model $aspectModel.getPreferredName($i18n.getLocale())</h1>
                <div class="dt-meta">$aspectModel.urn()</div>
            </div>
            <div class="dt-pill" title="Theme: professional documentation UI">
                <span class="dt-dot" aria-hidden="true"></span>
            </div>
        </div>
    </header>

    <div class="dt-wrap">
        <div class="dt-layout">
            <main class="dt-content">
                <section class="dt-card">
                    <div id="documentation" class="md-content">
                        <section class="am-preview" aria-label="Aspect Model preview">
                            ##            Uncomment these changes when editor will be connected
                            ##            <div class="am-preview__head">
                            ##              <div class="am-preview__title">Aspect Model Preview</div>
                            ##              <div class="am-preview__actions">
                            ##                <a href="#" class="am-btn am-btn--primary" role="button">Open in Viewer</a>
                            ##                <a href="#" class="am-btn" role="button">Login to Edit</a>
                            ##              </div>
                            ##            </div>
                            <p class="am-preview__text">
                                This page provides a lightweight, in-browser preview of the model. Use the interactive diagram (pan + zoom) to understand the
                                overall structure.
                                The sidebar contains the full structure tree. For advanced navigation (smart search, drag, deep details), open the dedicated
                                viewer.
                            </p>
                            <div class="am-preview__hint">
                                Tip: Use the mouse wheel (or trackpad) to zoom. Drag to pan. Double-click to reset.
                            </div>
                        </section>

                        <!-- Aspect Model Description -->
                        #if($aspectModel.getDescription($i18n.getLocale()) && $aspectModel.getDescription($i18n.getLocale()).trim().length() > 0)
                            <div class="pb-5">
                                $aspectModel.getDescription($i18n.getLocale())
                            </div>
                        #end

                        <!-- Aspect Model Diagram -->
                        #diagram( $i18n )

                        <!-- Aspect Model Properties and related Types -->
                        #if( !$aspectModel.getProperties().isEmpty() )
                            <div class="heading" id=properties">
                                #title( $i18n.getText("docu.label.properties") "properties" "2" )

                        #foreach( $property in $aspectModelHelper.sortPropertiesByPreferredName( $aspectModel.getProperties(), $i18n.getLocale() ) )
                                #property( $property $aspectModel $aspectModelHelper $i18n "3" )
                            #end
                            </div>
                        #end

                        <!-- Aspect Model Operations and related Types -->
                        #if( !$aspectModel.operations.isEmpty() )
                            <div class="heading" id="operations">
                                #title( $i18n.getText("docu.label.operations") "operations" "2" )

                        #foreach( $operation in $aspectModelHelper.sortOperationsByPreferredName( $aspectModel.getOperations(), $i18n.getLocale() ) )
                                #operation( $operation $aspectModelHelper $i18n "3" )
                            #end
                            </div>
                        #end

                        <!-- Aspect Model Entities and related Types -->
                        #if( !$aspectModelHelper.getEntities($aspectModel).isEmpty())
                            <div class="heading" id="entities">
                                #title( $i18n.getText("docu.label.entities") "entities" "2" )

                        #foreach( $entity in $aspectModelHelper.sortEntitiesByPreferredName( $aspectModelHelper.getEntities($aspectModel), $i18n.getLocale() ) )
                                #entity( $entity $aspectModelHelper $i18n "3" )
                            #end
                            </div>
                        #end

                        <!-- Aspect Model Events and related Types -->
                        #if( !$aspectModel.events.isEmpty() )
                            <div class="heading" id="events">
                                #title( $i18n.getText("docu.label.events") "events" "2" )

                #foreach( $event in $aspectModelHelper.sortEventsByPreferredName( $aspectModel.getEvents(), $i18n.getLocale() ) )
                                #event( $event $aspectModel $aspectModelHelper $i18n "3" )
                            #end
                            </div>
                        #end

                        <div class=" pt-15">
                            <a href="javascript:toggleLicenseDetails()" class="underline text-sm">Third party licenses</a>
                            <div class="grid grid-cols-1 gap-4" style="display:none" id="license-detail">
                                <div class="font-bold pt-5">Panzoom</div>
                                <div>panzoom_license_placeholder</div>
                                <div class="font-bold pt-5">Tailwind</div>
                                <div>tailwind_license_placeholder</div>
                                <div class="font-bold pt-5">Tocbot</div>
                                <div>tocbot_license_placeholder</div>
                            </div>
                        </div>

                    </div>
                </section>
            </main>
            <aside aria-label="Table of contents" class="dt-toc">
                <h4 id="content-title">$i18n.getText("docu.label.table-of-contents")</h4>
                <div id="documentation-toc" class="is-position-fixed">
                    <ol class="toc-list"></ol>
                </div>
            </aside>
        </div>
    </div>
    <script>
        function toggleLicenseDetails() {
            let section = document.getElementById('license-detail');
            if (section.style.display === 'none') {
                section.style.display = 'block';
            } else {
                section.style.display = 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            tocbot.init({
                tocSelector: '#documentation-toc',
                contentSelector: '#documentation',
                headingSelector: 'h2, h3, h4, h5',
                collapseDepth: 0,
                positionFixedSelector: '#documentation-toc',
                scrollSmooth: true,
                headingsOffset: 125,
                scrollSmoothOffset: -125,
            });
        });
    </script>
</div>